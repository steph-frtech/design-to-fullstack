{
	"name": "backend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"dev": "tsx watch --env-file=../.env src/server.ts",
		"start": "tsx --env-file=../.env src/server.ts",
		"mcp": "tsx --env-file=../.env src/mcp-server.ts",
		"build": "tsc --noEmit",
		"typecheck": "tsc --noEmit",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"seed": "tsx --env-file=../.env src/seed.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@hono/zod-validator": "^0.4.2",
		"@modelcontextprotocol/sdk": "^1.0.4",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"better-auth": "^1.1.4",
		"hono": "^4.6.14",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"dotenv": "^16.4.7",
		"prisma": "^7.8.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
